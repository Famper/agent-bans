# Database
DATABASE_URL="file:./prisma/dev.db"

# Uploads directory (absolute or relative to project root)
UPLOAD_DIR="./uploads"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="please-change-me-to-a-long-random-string"
AUTH_TRUST_HOST="true"

# Optional: seed a demo user (demo@example.com / demo1234) on first boot
SEED_DEMO_USER="0"

# ─── Hermes REST API для агентов (опционально) ───────────────────
# Включает Bearer-аутентификацию для /api/tasks и /api/boards/*.
# Без переменной — режим dev (любой запрос пропускается). В проде ОБЯЗАТЕЛЬНО задайте.
# Сгенерировать: openssl rand -hex 32
# KANBAN_API_KEY=

# Параметры для `npm run db:seed:agent-board` — bootstrap агентского борда.
# AGENT_BOARD_ID=board-project-alpha
# AGENT_BOARD_NAME="AI Revolution"
# AGENT_BOARD_OWNER_EMAIL=agent-bot@local
