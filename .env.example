# Database
DATABASE_URL="file:./prisma/dev.db"

# Uploads directory (absolute or relative to project root)
UPLOAD_DIR="./uploads"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="please-change-me-to-a-long-random-string"
AUTH_TRUST_HOST="true"

# Optional: seed a demo user (demo@example.com / demo1234) on first boot
SEED_DEMO_USER="0"

# Общая доска: все залогиненные юзеры видят и редактируют ОДНУ доску, а не
# создают свою при первом заходе. Какую именно — определяется так:
#   1. SHARED_BOARD_ID, если задан и доска с таким id существует (пин к
#      конкретной доске — для ai-revolution это тот же id, что HERMES_BOARD_ID);
#   2. иначе самая ранняя по дате создания (на проде — агентская доска).
# Оставь пустым для zero-config — fallback на самую раннюю доску.
# SHARED_BOARD_ID=board-project-alpha

# ─── Hermes REST API для агентов (опционально) ───────────────────
# Включает Bearer-аутентификацию для /api/tasks и /api/boards/*.
# Без переменной — режим dev (любой запрос пропускается). В проде ОБЯЗАТЕЛЬНО задайте.
# Сгенерировать: openssl rand -hex 32
# KANBAN_API_KEY=

# Параметры для `npm run db:seed:agent-board` — bootstrap агентского борда.
# AGENT_BOARD_ID=board-project-alpha
# AGENT_BOARD_NAME="AI Revolution"
# AGENT_BOARD_OWNER_EMAIL=agent-bot@local

# ─── Redis pub/sub событий (опционально) ─────────────────────────
# Если задан — на каждую мутацию карточек/комментариев публикуется событие в
# канал "agent-bans:events". Внешние агенты подписываются и реагируют мгновенно
# (push) вместо polling. Без переменной слой выключен (no-op), polling работает
# как раньше. В docker-compose сервис redis уже выставляет это значение.
# REDIS_URL=redis://localhost:6379
